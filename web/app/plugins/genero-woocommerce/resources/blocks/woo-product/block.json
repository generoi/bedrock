{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "genero-woocommerce/woo-product",
  "title": "WooCommerce Product",
  "description": "Display the WooCommerce single product block for the current product",
  "category": "woocommerce",
  "icon": "products",
  "usesContext": ["postId"],
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide"
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "html": false
  },
  "example": {},
  "editorScript": "file:./index.js",
  "style": "file:./style.css"
}
